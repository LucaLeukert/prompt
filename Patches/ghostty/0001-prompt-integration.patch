+@_cdecl("ghostty_swift_manual_io_write")
+private func ghosttySwiftManualIOWrite(
+    _ userdata: UnsafeMutableRawPointer?,
+    _ bytes: UnsafePointer<CChar>?,
+    _ count: UInt
+) {
+    guard let userdata, let bytes, count > 0 else { return }
+    // AppKit delivers keyboard, mouse, and IME input on the main thread. A
+    // manual terminal may also emit protocol replies while parsing output
+    // (for example, device-attribute responses) on its terminal thread. Those
+    // replies already came from the authoritative terminal and must not be
+    // sent through the remote PTY a second time.
+    guard Thread.isMainThread else { return }
+    let data = Data(bytes: bytes, count: Int(count))
+    let view = Unmanaged<Ghostty.SurfaceView>.fromOpaque(userdata).takeUnretainedValue()
+    MainActor.assumeIsolated { view.manualIOWriteHandler?(data) }
+}
